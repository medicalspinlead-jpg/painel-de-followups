generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum LeadStage {
  desqualificado
  dia1
  dia2
  dia3
  aguarda_7_dias
}

model Category {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("bg-blue-500")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages FollowupMessage[]
  leads    Lead[]

  @@map("categories")
}

model FollowupMessage {
  id         String   @id @default(cuid())
  categoryId String
  order      Int // posicao 1-6 dentro da categoria
  dayOffset  Int // dias apos o contato inicial
  time       String // horario no formato HH:mm
  message    String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("followup_messages")
}

model Lead {
  id         String     @id @default(cuid())
  name       String
  email      String     @default("")
  phone      String     @default("")
  categoryId String?
  stage      LeadStage @default(dia1)
  notes      String     @default("")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  // Âncora do ciclo atual: a sequência dia1/dia2/dia3 é contada a partir daqui.
  // No 1º ciclo é igual a createdAt; ao reiniciar (após "aguarda_7_dias") é
  // atualizada para o instante do reinício, recomeçando a contagem dos dias.
  cycleStartedAt DateTime @default(now())
  // Quando o lead entrou em "aguarda_7_dias". Usado para contar os 7 dias úteis
  // de espera antes de reiniciar o ciclo. Null fora dessa etapa.
  waitingSince   DateTime?

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  logs     FollowupLog[]

  @@index([categoryId])
  @@index([stage])
  @@map("leads")
}

// Registro de cada follow-up efetivamente enviado ao webhook.
// Garante idempotência: um mesmo (lead, mensagem, data-alvo) nunca é enviado
// duas vezes, mesmo que o cron/agendador rode várias vezes no mesmo dia.
model FollowupLog {
  id         String   @id @default(cuid())
  leadId     String
  messageId  String
  targetDate String // data-alvo no formato YYYY-MM-DD (horário de Brasília)
  scheduled  String // horário agendado HH:mm da mensagem
  status     String   @default("delivered") // delivered | failed
  sentAt     DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId, messageId, targetDate])
  @@index([leadId])
  @@map("followup_logs")
}

model Settings {
  id                  String  @id @default("default")
  companyName         String  @default("Minha Empresa")
  defaultFollowupTime String  @default("09:00")
  sendWeekends        Boolean @default(false)
  webhookUrl          String  @default("")
  webhookSecret       String  @default("")
  webhookEnabled      Boolean @default(false)

  @@map("settings")
}
